function upP()
    for _, v in pairs(PlayerHolder:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP then
            local b = Instance.new("TextButton", PlayerHolder)
            b.Size = UDim2.new(1, 0, 0, 38)
            b.BackgroundColor3 = Blacklist[p.Name] and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(60, 60, 60)
            b.Text = (Blacklist[p.Name] and LangData[CurrentLang].Hidden or LangData[CurrentLang].Visible) .. p.Name
            b.TextColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", b)
            b.MouseButton1Click:Connect(function() Blacklist[p.Name] = not Blacklist[p.Name] upP() end)
        end
    end
end

